# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development           # development | production
APP_TITLE="Investment Research Dashboard"
APP_VERSION="1.0.0"

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/investment_db

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# CORS (comma-separated origins)
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Phase 3A: AI Research Engine
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-abcdqrstefgh5678abcdqrstefgh5678abcdqrst

# Model to use. gpt-4o for highest quality, gpt-4o-mini for lower cost.
OPENAI_MODEL=gpt-4o

# OPTIONAL — get from https://newsapi.org (free tier = 100 req/day)
# Leave blank to skip news enrichment (report still works without it)
NEWS_API_KEY=

# How long to cache a generated report before re-running the AI pipeline (minutes)
REPORT_CACHE_MINUTES=60
